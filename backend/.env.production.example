# ShopMind AI Backend production environment template
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO

ALLOWED_ORIGINS=https://your-frontend-domain

MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=shopmind_ai

JWT_SECRET_KEY=replace-with-strong-random-jwt-secret
REFRESH_TOKEN_EXPIRE_DAYS=30

RAPIDAPI_KEY=replace-with-your-rapidapi-key
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com
RAPIDAPI_CATEGORY_CACHE_TTL_SECONDS=1800
RAPIDAPI_CATEGORY_CACHE_STALE_SECONDS=21600

GEMINI_API_KEY=replace-with-your-gemini-api-key
GROQ_API_KEY=replace-with-your-groq-api-key
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_SEARCH_RESULTS=20
DEFAULT_SEARCH_RESULTS=5
PIPELINE_INTERVAL_HOURS=6
CIRCUIT_BREAKER_THRESHOLD=3
INR_TO_USD=0.012
